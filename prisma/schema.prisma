generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum LeadSource {
  CONTACT_FORM
  BUDGET_FORM
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  LOST
}

enum PageContentKind {
  GENERIC
  HOME
  ABOUT
  SERVICES
}

enum RoleName {
  ADMIN
  EDITOR
  VIEWER
}

enum PostStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model Lead {
  id          String     @id @default(cuid())
  name        String
  email       String
  phone       String?
  projectType String?
  message     String
  source      LeadSource @default(CONTACT_FORM)
  status      LeadStatus @default(NEW)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  notes       LeadNote[]
}

model LeadNote {
  id          String   @id @default(cuid())
  leadId      String
  note        String
  authorEmail String?
  createdAt   DateTime @default(now())
  lead        Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
}

model Page {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  description String?
  contentKind PageContentKind @default(GENERIC)
  schemaVersion Int    @default(1)
  draftContent Json?
  publishedContent Json?
  content     Json?
  published   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model User {
  id        String     @id @default(cuid())
  email     String     @unique
  name      String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  userRoles UserRole[]
}

model Role {
  id        String     @id @default(cuid())
  name      RoleName   @unique
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  userRoles UserRole[]
}

model UserRole {
  id         String   @id @default(cuid())
  userId     String
  roleId     String
  assignedAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
}

model HomeContent {
  id              String   @id @default(cuid())
  key             String   @unique @default("default")
  heroEyebrow     String
  heroTitle       String
  heroDescription String
  ctaBudgetLabel  String
  ctaWhatsappLabel String
  services        String[]
  differentials   String[]
  featuredCases   Json
  testimonials    Json?
  showTestimonials Boolean @default(false)
  published       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model AboutContent {
  id               String   @id @default(cuid())
  key              String   @unique @default("default")
  title            String
  subtitle         String
  historyTitle     String
  historyText      String
  values           String[]
  methodology      String[]
  stack            String[]
  published        Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model ServiceContent {
  id             String   @id @default(cuid())
  slug           String   @unique
  name           String
  summary        String
  heroTitle      String
  heroDescription String
  details        String[]
  seoTitle       String?
  seoDescription String?
  published      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model CaseContent {
  id                String   @id @default(cuid())
  slug              String   @unique
  title             String
  summary           String
  challenge         String
  solution          String
  ctaLabel          String?
  ctaUrl            String?
  results           String[]
  stack             String[]
  imageUrls         String[]
  testimonialQuote  String?
  testimonialAuthor String?
  testimonialRole   String?
  showTestimonial   Boolean  @default(false)
  seoTitle          String?
  seoDescription    String?
  published         Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  mediaLinks        CaseMedia[]
}

model MediaAsset {
  id           String      @id
  provider     String
  storageKey   String
  url          String
  optimizedUrl String
  bytes        Int
  mimeType     String
  width        Int?
  height       Int?
  altText      String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  caseLinks    CaseMedia[]
}

model CaseMedia {
  caseId    String
  mediaId   String
  position  Int       @default(0)
  createdAt DateTime  @default(now())
  case      CaseContent @relation(fields: [caseId], references: [id], onDelete: Cascade)
  media     MediaAsset  @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@id([caseId, mediaId])
  @@index([mediaId])
}

model Category {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  posts       Post[]
}

model Tag {
  id        String    @id @default(cuid())
  slug      String    @unique
  name      String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  postTags  PostTag[]
}

model Post {
  id             String     @id @default(cuid())
  slug           String     @unique
  title          String
  excerpt        String
  coverImageUrl  String?
  contentHtml    String
  status         PostStatus @default(DRAFT)
  publishedAt    DateTime?
  categoryId     String?
  category       Category?  @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  postTags       PostTag[]
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
}

model PostTag {
  postId     String
  tagId      String
  assignedAt DateTime @default(now())
  post       Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag        Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
  @@index([tagId])
}

model AppSetting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}

model AdminUserPermission {
  id        String   @id @default(cuid())
  email     String   @unique
  role      RoleName
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
